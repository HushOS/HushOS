# we need to figure out how to handle this with preview deployments
NEXT_PUBLIC_DOMAIN=hushos.com

# vercel, standalone
DEPLOY_TARGET=standalone

# postgres connection string
DATABASE_URL=

# email from address, ex: "HushOS <hey@hushos.com>"
EMAIL_FROM="HushOS <hey@hushos.com>"

# console, smtp, resend, default is console
EMAIL_PROVIDER=console

# if email provider is resend, get your key from resend.com
RESEND_API_KEY=

# if email provider is smtp
SMTP_HOST=
# defaults to 587
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# true or 1, defaults to true
SMTP_SECURE=true

# secret used to sign cookies
COOKIE_SIGNING_SECRET=

# url of the plausible instance, if not supplied, then analytics will be disabled
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
